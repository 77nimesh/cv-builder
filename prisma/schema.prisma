// prisma/schema.prisma
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                                String                   @id @default(cuid())
  name                              String?
  email                             String                   @unique
  passwordHash                      String
  role                              String                   @default("USER")
  emailVerified                     DateTime?
  anonymizedAt                      DateTime?
  createdAt                         DateTime                 @default(now())
  updatedAt                         DateTime                 @updatedAt
  resumes                           Resume[]
  imageAssets                       ImageAsset[]
  emailVerificationTokens           EmailVerificationToken[]
  passwordResetTokens               PasswordResetToken[]
  supportAccessGrantsForUser        SupportAccessGrant[]     @relation("SupportAccessGrantTargetUser")
  supportAccessGrantsAsSupportUser  SupportAccessGrant[]     @relation("SupportAccessGrantSupportUser")
  supportAccessGrantsGrantedByUser  SupportAccessGrant[]     @relation("SupportAccessGrantGrantedByUser")
  auditLogsAuthored                 AuditLog[]               @relation("AuditLogActorUser")
  auditLogsForOwnedTargets          AuditLog[]               @relation("AuditLogTargetOwnerUser")
  privacyRequestsForSubjectUser     PrivacyRequest[]         @relation("PrivacyRequestSubjectUser")
  privacyRequestsRequestedByUser    PrivacyRequest[]         @relation("PrivacyRequestRequestedByUser")
  privacyRequestsAssignedToUser     PrivacyRequest[]         @relation("PrivacyRequestAssignedToUser")
  privacyRequestsResolvedByUser     PrivacyRequest[]         @relation("PrivacyRequestResolvedByUser")
  payments                          Payment[]
  entitlements                      Entitlement[]
  paymentReceipts                   PaymentReceipt[]

  @@index([role])
}

model Resume {
  id                  String                @id @default(cuid())
  userId              String?
  title               String
  template            String                @default("modern-1")
  themeColor          String?
  fontFamily          String?
  data                Json
  photoPath           String?
  photoAssetId        String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  user                User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  photoAsset          ImageAsset?           @relation(fields: [photoAssetId], references: [id], onDelete: SetNull)
  supportAccessGrants SupportAccessGrant[]
  payments            Payment[]
  entitlements        Entitlement[]

  @@index([userId])
  @@index([photoAssetId])
}

model ImageAsset {
  id              String   @id @default(cuid())
  userId          String
  kind            String   @default("resume-photo")
  storageProvider String   @default("local")
  storageKey      String   @unique
  sourceFileName  String?
  mimeType        String
  byteSize        Int
  width           Int?
  height          Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumes         Resume[]

  @@index([userId, createdAt])
  @@index([userId, kind])
}

model Plan {
  id                      String        @id @default(cuid())
  code                    String        @unique
  name                    String
  description             String
  status                  String        @default("active")
  billingMode             String        @default("free")
  currency                String        @default("USD")
  amountCents             Int           @default(0)
  templateLimit           Int           @default(2)
  exportEnabled           Boolean       @default(false)
  exportResumeScoped      Boolean       @default(false)
  downloadLimit           Int?
  entitlementDurationDays Int?
  isPublic                Boolean       @default(true)
  sortOrder               Int           @default(0)
  metadata                Json?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  payments                Payment[]
  entitlements            Entitlement[]

  @@index([status, isPublic])
  @@index([billingMode])
  @@index([sortOrder])
}

model Payment {
  id                     String           @id @default(cuid())
  userId                 String
  planId                 String
  resumeId               String?
  provider               String           @default("paypal")
  providerEnvironment    String           @default("sandbox")
  providerOrderId        String?          @unique
  providerCaptureId      String?          @unique
  providerPayerId        String?
  status                 String           @default("created")
  amountCents            Int
  currency               String           @default("USD")
  rawProviderStatus      String?
  approvalUrl            String?
  idempotencyKey         String?          @unique
  webhookEventId         String?          @unique
  providerOrderPayload   Json?
  providerCapturePayload Json?
  metadata               Json?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  approvedAt             DateTime?
  capturedAt             DateTime?
  cancelledAt            DateTime?
  failedAt               DateTime?
  user                   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                   Plan             @relation(fields: [planId], references: [id])
  resume                 Resume?          @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  entitlements           Entitlement[]
  receipt                PaymentReceipt?

  @@index([userId, createdAt])
  @@index([planId])
  @@index([resumeId])
  @@index([provider, providerEnvironment])
  @@index([status])
  @@index([createdAt])
}

model Entitlement {
  id                 String    @id @default(cuid())
  userId             String
  planId             String?
  paymentId          String?
  resumeId           String?
  status             String    @default("active")
  source             String    @default("payment")
  templateLimit      Int       @default(2)
  exportEnabled      Boolean   @default(false)
  exportResumeScoped Boolean   @default(false)
  downloadLimit      Int?
  downloadsUsed      Int       @default(0)
  startsAt           DateTime  @default(now())
  expiresAt          DateTime?
  revokedAt          DateTime?
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan               Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  payment            Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  resume             Resume?   @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, resumeId])
  @@index([planId])
  @@index([paymentId])
  @@index([resumeId])
  @@index([expiresAt])
  @@index([createdAt])
}

model PaymentReceipt {
  id                 String    @id @default(cuid())
  paymentId          String    @unique
  userId             String
  receiptNumber      String    @unique
  status             String    @default("pending")
  emailTo            String
  subject            String
  devEmailPreviewId  String?
  devEmailPreviewUrl String?
  sentAt             DateTime?
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  payment            Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model SupportAccessGrant {
  id              String    @id @default(cuid())
  targetUserId    String
  targetResumeId  String?
  supportUserId   String
  grantedByUserId String?
  reason          String
  startsAt        DateTime  @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  targetUser    User    @relation("SupportAccessGrantTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)
  targetResume  Resume? @relation(fields: [targetResumeId], references: [id], onDelete: Cascade)
  supportUser   User    @relation("SupportAccessGrantSupportUser", fields: [supportUserId], references: [id], onDelete: Cascade)
  grantedByUser User?   @relation("SupportAccessGrantGrantedByUser", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@index([targetUserId])
  @@index([targetResumeId])
  @@index([supportUserId])
  @@index([grantedByUserId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model AuditLog {
  id                String   @id @default(cuid())
  actorUserId       String?
  actorRole         String?
  action            String
  targetType        String
  targetId          String?
  targetOwnerUserId String?
  metadata          Json?
  createdAt         DateTime @default(now())

  actorUser       User? @relation("AuditLogActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetOwnerUser User? @relation("AuditLogTargetOwnerUser", fields: [targetOwnerUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetOwnerUserId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model PrivacyRequest {
  id                String    @id @default(cuid())
  type              String
  status            String    @default("OPEN")
  subjectUserId     String
  requestedByUserId String?
  assignedToUserId  String?
  resolvedByUserId  String?
  reason            String?
  requestDetails    Json?
  resolutionNotes   String?
  requestedAt       DateTime  @default(now())
  dueAt             DateTime?
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  subjectUser     User  @relation("PrivacyRequestSubjectUser", fields: [subjectUserId], references: [id], onDelete: Cascade)
  requestedByUser User? @relation("PrivacyRequestRequestedByUser", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  assignedToUser  User? @relation("PrivacyRequestAssignedToUser", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  resolvedByUser  User? @relation("PrivacyRequestResolvedByUser", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([type, status])
  @@index([subjectUserId])
  @@index([requestedByUserId])
  @@index([assignedToUserId])
  @@index([resolvedByUserId])
  @@index([dueAt])
  @@index([createdAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  email     String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([email])
}